# Database (defaults to the committed SQLite DB at app/db/property_sales.db)
# DATABASE_URL=sqlite+aiosqlite:///./app/db/property_sales.db

# LLM provider: "ollama" (local) or "openai" (any OpenAI-compatible endpoint,
# e.g. Groq, Together, OpenRouter — set base URL and API key accordingly)
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2
LLM_API_KEY=
LLM_TIMEOUT=60

# Rate limiting for POST /agents/chat (per client IP)
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

# Seeding
# SEED_CSV_PATH=./data/Challenge.csv
